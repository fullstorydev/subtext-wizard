{
  "name": "@subtext/install",
  "version": "0.1.0",
  "description": "Set up Subtext session capture in your app using your own coding agent",
  "keywords": [
    "subtext",
    "fullstory",
    "session-capture",
    "setup",
    "install",
    "wizard",
    "cli"
  ],
  "type": "module",
  "bin": {
    "subtext-install": "dist/bin.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/bin.js"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "clipboardy": "^4.0.0",
    "open": "^10.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.6.3"
  }
}
